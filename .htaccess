# ================================
# Samley Teas  URL Rewriting & SEO
# ================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ================================
  # 1. HTTPS & WWW NORMALIZATION
  # ================================
  
  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ================================
  # 2. LEGACY URL REDIRECTS (301)
  # ================================
  
  # Homepage variants
  Redirect 301 /home_v02/ https://samleyteas.lk/
  
  # Contact pages
  Redirect 301 /contact-us/ https://samleyteas.lk/contact.html
  Redirect 301 /contact_v02/ https://samleyteas.lk/contact.html

  # About / Story pages
  Redirect 301 /our-story/ https://samleyteas.lk/story.html
  Redirect 301 /about-us/ https://samleyteas.lk/story.html
  Redirect 301 /our-story_v02/ https://samleyteas.lk/story.html

  # Blog pages
  Redirect 301 /blogs_v02/ https://samleyteas.lk/blogs.html
  Redirect 301 /author/samleyteas_admin/ https://samleyteas.lk/blogs.html
  Redirect 301 /category/uncategorized/ https://samleyteas.lk/blogs.html

  # Shop / Products
  Redirect 301 /our-teas/ https://samleyteas.lk/products.html
  Redirect 301 /shop_v02/ https://samleyteas.lk/products.html
  Redirect 301 /wholesale_v02/ https://samleyteas.lk/wholesale.html

  # ================================
  # 3. CLEAN URL REWRITES (INTERNAL)
  # ================================
  
  # Rewrite clean URLs to actual files with query strings
  # /products/category-name/  /products.html?category=category-name
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^products/([^/]+)/?$ /products.html?category=$1 [L,QSA]

  # /product/product-slug/  /product.html?product=product-slug
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^product/([^/]+)/?$ /product.html?product=$1 [L,QSA]

</IfModule>

# ================================
# 4. SECURITY & PERFORMANCE
# ================================

# Prevent directory listing
Options -Indexes

# ================================
# 5. GZIP COMPRESSION
# ================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
</IfModule>

