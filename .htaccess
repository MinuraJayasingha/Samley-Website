# =========================================
# Samley Teas – SEO & Clean URL Routing
# =========================================

RewriteEngine On
RewriteBase /


# =========================================
# FORCE NON-WWW / HTTPS ROOT DOMAIN
# =========================================
RewriteCond %{HTTP_HOST} ^www\.samleyteas\.lk$ [NC]
RewriteRule ^(.*)$ https://samleyteas.lk/$1 [R=301,L]


# =========================================
# OLD STATIC PAGES → NEW PAGES
# =========================================

Redirect 301 /home_v02/ https://samleyteas.lk/
Redirect 301 /contact-us/ https://samleyteas.lk/contact/
Redirect 301 /contact_v02/ https://samleyteas.lk/contact/
Redirect 301 /our-story/ https://samleyteas.lk/about-samley-teas/
Redirect 301 /about-us/ https://samleyteas.lk/about-samley-teas/
Redirect 301 /our-story_v02/ https://samleyteas.lk/about-samley-teas/
Redirect 301 /blogs_v02/ https://samleyteas.lk/blogs/
Redirect 301 /author/samleyteas_admin/ https://samleyteas.lk/blogs/
Redirect 301 /category/uncategorized/ https://samleyteas.lk/blogs/
Redirect 301 /our-teas/ https://samleyteas.lk/products/
Redirect 301 /shop_v02/ https://samleyteas.lk/products/


# =========================================
# OLD CATEGORY SLUGS → CLEAN CATEGORY URLS
# =========================================

Redirect 301 /iced-tea/ https://samleyteas.lk/products/iced-tea-collection/
Redirect 301 /black-tea-2/ https://samleyteas.lk/products/black-tea-collection/
Redirect 301 /black-tea-3/ https://samleyteas.lk/products/black-tea-collection/
Redirect 301 /green-tea/ https://samleyteas.lk/products/green-tea-collection/
Redirect 301 /signature-tea/ https://samleyteas.lk/products/signature-collection/
Redirect 301 /heritage-tea/ https://samleyteas.lk/products/heritage-collection/
Redirect 301 /regional-tea/ https://samleyteas.lk/products/regional-collection/
Redirect 301 /elegance-tea/ https://samleyteas.lk/products/elegance-collection/
Redirect 301 /luxury-tea/ https://samleyteas.lk/products/luxuary-collection/
Redirect 301 /designer-tea/ https://samleyteas.lk/products/designer-collection/
Redirect 301 /speciality-tea/ https://samleyteas.lk/products/speciality-collection/
Redirect 301 /wellness-tea/ https://samleyteas.lk/products/wellness-collection/
Redirect 301 /wellness-everyday-tea/ https://samleyteas.lk/products/wellness-collection/
Redirect 301 /tea-capsules/ https://samleyteas.lk/products/tea-capsules-collection/
Redirect 301 /gift-range/ https://samleyteas.lk/products/gift-collection/
Redirect 301 /gourmet-range/ https://samleyteas.lk/products/gourmet-collection/
Redirect 301 /organic-herbal-infusions/ https://samleyteas.lk/products/organic-teas-herbal-infusions-collection/
Redirect 301 /organic-herbal-infusions-2/ https://samleyteas.lk/products/organic-teas-herbal-infusions-collection/
Redirect 301 /iced-coffee/ https://samleyteas.lk/products/coffee-collection/
Redirect 301 /coconut-water-king-coconut-water/ https://samleyteas.lk/products/organic-coconut-water-collection/
Redirect 301 /organic-coconut-king-coconut/ https://samleyteas.lk/products/organic-king-coconut-water-collection/
Redirect 301 /coconut-milk-coconut-cream/ https://samleyteas.lk/products/organic-coconut-milk-collection/
Redirect 301 /coconut-flour-coconut-milk-powder/ https://samleyteas.lk/products/organic-coconut-flour-collection/
Redirect 301 /dedicated-coconut/ https://samleyteas.lk/products/organic-dessicated-coconut-collection/
Redirect 301 /virgin-coconut-oil/ https://samleyteas.lk/products/organic-coconut-oil-collection/
Redirect 301 /ceylon-organic-spices/ https://samleyteas.lk/products/ceylon-organic-spices-collection/


# =========================================
# REDIRECT .html FILES TO CLEAN URLS (BEFORE FILE CHECK!)
# =========================================

# /index.html → /
RewriteRule ^index\.html$ / [R=301,L]

# /contact.html → /contact/
RewriteRule ^contact\.html$ /contact/ [R=301,L]

# /blogs.html → /blogs/
RewriteRule ^blogs\.html$ /blogs/ [R=301,L]

# /products.html → /products/
RewriteRule ^products\.html$ /products/ [R=301,L]

# /story.html → /about-samley-teas/
RewriteRule ^story\.html$ /about-samley-teas/ [R=301,L]

# /wholesale.html → /wholesale/
RewriteRule ^wholesale\.html$ /wholesale/ [R=301,L]


# =========================================
# STOP REWRITING REAL FILES / FOLDERS
# =========================================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]


# =========================================
# QUERY-BASED → CLEAN URL
# =========================================

RewriteCond %{QUERY_STRING} ^product=([a-zA-Z0-9-]+)$ [NC]
RewriteRule ^product\.html$ /product/%1/? [R=301,L]

RewriteCond %{QUERY_STRING} ^category=([a-zA-Z0-9-]+)$ [NC]
RewriteRule ^products\.html$ /products/%1/? [R=301,L]

RewriteCond %{QUERY_STRING} ^main=([a-zA-Z0-9-]+)$ [NC]
RewriteRule ^products\.html$ /products/%1/? [R=301,L]

# Product query → clean product URL
RewriteCond %{QUERY_STRING} ^product=([a-zA-Z0-9-]+)$ [NC]
RewriteRule ^product\.html$ /product/%1/? [R=301,L]

# Category query (products/?category=slug)
RewriteCond %{QUERY_STRING} ^category=([a-zA-Z0-9-]+)$ [NC]
RewriteRule ^products/?$ /products/%1/? [R=301,L]

# Main query
RewriteCond %{QUERY_STRING} ^main=([a-zA-Z0-9-]+)$ [NC]
RewriteRule ^products/?$ /products/%1/? [R=301,L]

# =========================================
# CLEAN URL REWRITES (SERVE .html FILES)
# =========================================

RewriteRule ^/?$ index.html [L]
RewriteRule ^contact/?$ contact.html [L]
RewriteRule ^about-samley-teas/?$ story.html [L]
RewriteRule ^blogs/?$ blogs.html [L]
RewriteCond %{REQUEST_URI} !^/products/[a-z0-9-]+/?$
RewriteRule ^products/?$ products.html [L]
RewriteRule ^wholesale/?$ wholesale.html [L]


# =========================================
# PRODUCT/CATEGORY REWRITES
# =========================================

RewriteRule ^products/([a-zA-Z0-9-]+)/?$ products.html?category=$1 [L,QSA]
RewriteRule ^product/([a-zA-Z0-9-]+)/?$ product.html?slug=$1 [L,QSA]